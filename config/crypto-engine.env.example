# ==============================================================
# crypto-engine 서비스 환경변수 템플릿
# 사용법: cp config/crypto-engine.env.example config/crypto-engine.env
# 상세 설정은 Step 1-B에서 추가 예정
# ==============================================================

# ── 알고리즘 선택 (algorithm_factory.py 교체용 — Algorithm Agility) ──
KEM_ALGORITHM_ID=ML-KEM-768
DSA_ALGORITHM_ID=ML-DSA-65

# ── 서버 설정 ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Gunicorn workers 튜닝 ────────────────────────────────
# 시나리오별 변경 후 docker-compose up -d --build crypto-engine 으로 재기동
# 시나리오 A: workers=1 (직렬 베이스라인)
# 시나리오 B: workers=2 (기본값)
# 시나리오 C: workers=4 (병렬 최대 — 메모리 사용량 512m 초과 여부 모니터링 필요)
GUNICORN_WORKERS=4

# ── --preload 실험 제어 ──────────────────────────────────
# DISABLE_PRELOAD=0: --preload 활성 (기본 — worker 간 keypair 공유)
# DISABLE_PRELOAD=1: --preload 제거 — DSA_SECRET_KEY_B64, DSA_PUBLIC_KEY_B64 필수
DISABLE_PRELOAD=0

# ── Day 6: KEM secret_key AES-256-GCM 래핑 키 ────────────────
# base64(32-byte key). 운영 환경에서는 반드시 교체하세요.
# (32 null bytes)는 dev/CI 전용. 운영 배포 전 반드시 랜덤 32바이트로 교체 필요.
KEM_WRAP_KEY=changeme

# ── Day 6: crypto-engine → DB 연결 설정 ──────────────────────
# DB_PASSWORD는 POSTGRES_PASSWORD 와 동일한 값으로 설정하세요.
DB_HOST=db
DB_PORT=5432
DB_NAME=pqc_db
DB_USER=pqc
DB_PASSWORD=changeme

DSA_SECRET_KEY_B64=changeme
DSA_PUBLIC_KEY_B64=changeme