# ==============================================================
# crypto-engine 서비스 환경변수 템플릿
# 사용법: cp config/crypto-engine.env.example config/crypto-engine.env
# 상세 설정은 Step 1-B에서 추가 예정
# ==============================================================

# ── 알고리즘 선택 (algorithm_factory.py 교체용, Step 1-B) ──
ALGORITHM_ID=ML-KEM-768

# ── 서버 설정 ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ── KEM 래핑 키 (32바이트 base64 인코딩, 운영 환경에서 반드시 교체) ─
KEM_WRAP_KEY=changeme_replace_with_32byte_base64==

# ── DB 연결 (docker compose 기본값: db 서비스명) ──────────
DB_HOST=db
DB_PORT=5432
DB_NAME=pqc_db
DB_USER=pqc
DB_PASSWORD=changeme
