# ==============================================================
# PQC Security Project — Day 20 환경변수 교체 기동 테스트용
# 사용법: docker compose --env-file .env.test up -d
# 목적: 호스트명 교체만으로 다른 환경 기동 가능 여부 검증 (인수조건 3)
# ==============================================================

# ── Docker 보안 (Step 1-A) ─────────────────────────────────
DOCKER_CONTENT_TRUST=1

# ── PostgreSQL (Step 1-C) ──────────────────────────────────
POSTGRES_USER=pqc
POSTGRES_PASSWORD=qwebjhcvdjkxsucjhbshjsdfc2536153dsadhbj65dwqd
POSTGRES_DB=pqc_db

# ── Resource Limits ────────────────────────────────────────
CRYPTO_ENGINE_CPU_LIMIT=1.0
CRYPTO_ENGINE_MEM_LIMIT=512m
API_GATEWAY_CPU_LIMIT=0.5
API_GATEWAY_MEM_LIMIT=768m
DB_CPU_LIMIT=0.5
DB_MEM_LIMIT=256m
DASHBOARD_CPU_LIMIT=0.25
DASHBOARD_MEM_LIMIT=128m

# ── Algorithm Agility ─────────────────────────────────────
KEM_ALGORITHM_ID=ML-KEM-768
DSA_ALGORITHM_ID=ML-DSA-65

# ── Monitoring ────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme

# ── Host 교체 (Day 20 환경변수 교체 기동 테스트) ──────────
# docker-compose.yml 서비스 간 통신은 서비스명으로 라우팅되므로
# 아래 값은 외부 클라이언트 접속 엔드포인트 문서화 목적입니다.
CRYPTO_ENGINE_HOST=127.0.0.1
DB_HOST=127.0.0.1
GATEWAY_HOST=127.0.0.1
