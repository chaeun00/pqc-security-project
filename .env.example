# ==============================================================
# PQC Security Project — 루트 환경변수 템플릿
# 사용법: cp .env.example .env  (이후 민감 값 수정)
# ==============================================================

# ── Docker 보안 (Step 1-A) ─────────────────────────────────
DOCKER_CONTENT_TRUST=1

# ── PostgreSQL (Step 1-C) ──────────────────────────────────
POSTGRES_USER=pqc
POSTGRES_PASSWORD=qwebjhcvdjkxsucjhbshjsdfc2536153dsadhbj65dwqd    # 반드시 변경 (운영 환경에서 강력한 패스워드 사용)
POSTGRES_DB=pqc_db

# ── Resource Limits (단일 진실 공급원 — 운영 배포 시 값 조정)
# 개발 기본값. 운영 권장: crypto-engine CPU=2.0/MEM=1g, api-gateway CPU=1.0/MEM=1g
CRYPTO_ENGINE_CPU_LIMIT=1.0
CRYPTO_ENGINE_MEM_LIMIT=512m
API_GATEWAY_CPU_LIMIT=0.5
API_GATEWAY_MEM_LIMIT=768m
DB_CPU_LIMIT=0.5
DB_MEM_LIMIT=256m
DASHBOARD_CPU_LIMIT=0.25
DASHBOARD_MEM_LIMIT=128m

# ── Algorithm Agility (Day 8 — Step 1) ────────────────────────────────────────
# 재빌드 없이 환경변수만 교체하여 알고리즘 전환 가능
# KEM 지원값: ML-KEM-512 | ML-KEM-768 (기본) | ML-KEM-1024
KEM_ALGORITHM_ID=ML-KEM-768
# DSA 지원값: ML-DSA-44 | ML-DSA-65 (기본) | ML-DSA-87
DSA_ALGORITHM_ID=ML-DSA-65
